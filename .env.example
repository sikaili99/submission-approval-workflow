# ─────────────────────────────────────────────────────────────────────────
# LOCAL DEV ONLY. These defaults let the stack boot with zero edits via
# `docker compose up`. Override every value in any real deployment.
# ─────────────────────────────────────────────────────────────────────────

# Postgres (consumed by docker-compose and Prisma)
POSTGRES_USER=app
POSTGRES_PASSWORD=app
POSTGRES_DB=approvals

# Connection string used by the backend / Prisma.
# Host "db" is the docker-compose service name; use localhost when running
# the backend outside Docker against the compose Postgres.
DATABASE_URL=postgresql://app:app@db:5432/approvals?schema=public

# Backend
PORT=4000

# Cloudinary (optional file attachments). Leave blank to disable uploads;
# the API then returns 503 for attachment requests and everything else works.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Attachment limits
MAX_UPLOAD_BYTES=5242880
